---
import { Image } from 'astro:assets';  // ← 追加
import "../layouts/heroSection.css";

const topics = [
  { id: 1, image: "/images/topic1.jpg", title: "Topic 1" },
  { id: 2, image: "/images/topic2.jpg", title: "Topic 2" },
  { id: 3, image: "/images/topic3.jpg", title: "Topic 3" },
  { id: 4, image: "/images/topic4.jpg", title: "Topic 4" },
];
---

<div class="hero-section">
  <div class="slide">
    <Image
      src={topics[0].image}
      alt={topics[0].title}
      width={1200}
      height={600}
      loading="eager"
    />
  </div>
  <div class="dots">
    {topics.map((topic, index) => (
      <span
        class={`dot ${index === 0 ? "active" : ""}`}
        data-index={index}
      ></span>
    ))}
  </div>
</div>

<script src="../scripts/heroScript.js"></script>