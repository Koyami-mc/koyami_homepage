---
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import "../layouts/styles.css";
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

// self-releases と others を両方取得して結合
const selfReleases = await getCollection('self-releases');
const others = await getCollection('others');
const allAlbums = [...selfReleases, ...others];

// 日付の新しい順にソートして上位4件を取得
const recentAlbums = allAlbums
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

// 最新日を基準に「New!」を付ける対象を決める
// 最新の日付と同じ日付のアルバムは全部 New! にする(同時リリース対応)
const latestDate = recentAlbums[0]?.data.date;
---

<Layout>
  <main>
    <Header />

    <section class="hero">
      <div class="icon-container">
        <Image
          src="/images/icon.jpg"
          alt="Koyami Icon"
          class="site-icon"
          width={200}
          height={200}
          loading="eager"
        />
      </div>
      <h1 class="site-title">こやみ Official Website</h1>
    </section>

    <section class="latest-works">
      <h2 class="futomoji">Recent Works</h2>
      <div class="album-list">
        {recentAlbums.map((album) => (
          <div class="album">
            {album.data.date === latestDate && <div class="new-label">New!</div>}
            <a href={`albums/${album.id}`}>
              <Image
                src={album.data.image}
                alt={`${album.data.title} cover`}
                class="album-cover"
                width={300}
                height={300}
                loading="lazy"
              />
            </a>
            <div class="album-info">
              <h3 class="album-title">{album.data.title}</h3>
              <p class="album-description">{album.data.about}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="pickup-video">
      <h2 class="futomoji">Pickup Video</h2>
      <div class="video-container">
        <iframe
          src="https://www.youtube.com/embed/UIaprefPPOg?si=r0d9rNZA3ahmfO7f"
          title="YouTube video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen></iframe>
      </div>
    </section>
  </main>
  <Footer />
</Layout>